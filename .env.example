# Copy to .env and adjust for local or server deployment.

SAVE_REPOSITORY_TYPE=postgres
DATABASE_URL=postgresql+psycopg://monirensheng:monirensheng@localhost:5432/monirensheng

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=monirensheng
POSTGRES_USER=monirensheng
POSTGRES_PASSWORD=change_me

AUTO_CREATE_TABLES=true
ENABLE_DEV_ROUTES=true
DEFAULT_RULE_VERSION=v1

# PostgreSQL integration tests (optional)
RUN_POSTGRES_TESTS=0
TEST_DATABASE_URL=postgresql+psycopg://monirensheng:monirensheng@localhost:5432/monirensheng_test
