# Copy to .env for local play. Do not commit real .env files.

ENVIRONMENT=local
LOG_LEVEL=INFO

SAVE_REPOSITORY_TYPE=sqlite
SQLITE_DATABASE_PATH=data/local_save.sqlite3

DATABASE_URL=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=monirensheng
POSTGRES_USER=monirensheng_user
POSTGRES_PASSWORD=change_me

AUTO_CREATE_TABLES=false
ENABLE_DEV_ROUTES=true
DEFAULT_RULE_VERSION=v1

BACKEND_HOST=127.0.0.1
BACKEND_PORT=4321
CORS_ALLOWED_ORIGINS=http://127.0.0.1:1234,http://localhost:1234

# Frontend build-time variable (Vite)
VITE_API_BASE_URL=http://127.0.0.1:4321

# PostgreSQL integration tests (optional advanced persistence)
RUN_POSTGRES_TESTS=0
TEST_DATABASE_URL=postgresql+psycopg://monirensheng_user:change_me@localhost:5432/monirensheng_test

# Optional PostgreSQL deployment (not the default local path):
# ENVIRONMENT=production
# SAVE_REPOSITORY_TYPE=postgres
# DATABASE_URL=postgresql+psycopg://monirensheng_user:change_me@localhost:5432/monirensheng
# AUTO_CREATE_TABLES=true
# ENABLE_DEV_ROUTES=false

# Optional in-memory mode (no persistence):
# SAVE_REPOSITORY_TYPE=memory
