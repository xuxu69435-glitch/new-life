# Copy to .env on the target machine. Do not commit real .env files.

ENVIRONMENT=development
LOG_LEVEL=INFO

SAVE_REPOSITORY_TYPE=memory
DATABASE_URL=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=monirensheng
POSTGRES_USER=monirensheng_user
POSTGRES_PASSWORD=change_me

AUTO_CREATE_TABLES=false
ENABLE_DEV_ROUTES=true
DEFAULT_RULE_VERSION=v1

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend build-time variable (Vite)
# VITE_API_BASE_URL=http://localhost:8000

# PostgreSQL integration tests (optional)
RUN_POSTGRES_TESTS=0
TEST_DATABASE_URL=postgresql+psycopg://monirensheng_user:change_me@localhost:5432/monirensheng_test

# Production example (placeholders only):
# ENVIRONMENT=production
# SAVE_REPOSITORY_TYPE=postgres
# DATABASE_URL=postgresql+psycopg://monirensheng_user:change_me@localhost:5432/monirensheng
# AUTO_CREATE_TABLES=false
# ENABLE_DEV_ROUTES=false
# BACKEND_PORT=50002
# CORS_ALLOWED_ORIGINS=http://your-host:50001
# VITE_API_BASE_URL=http://your-host:50002
